# Scanner Service Production Environment Configuration
# Copy this file to .env.prod and fill in the values

# =============================================================================
# AUTHENTICATION
# =============================================================================

# API key for scanner service authentication
# Generate a secure random key: openssl rand -hex 32
SCANNER_API_KEY=your_scanner_api_key_here

# Scan provider: github_actions_platform (required for production)
SCAN_PROVIDER=github_actions_platform

# Active job configuration
SCAN_ACTIVE_JOB_TTL_MINUTES=120
SCAN_MAX_ACTIVE_TEMPLATES_PER_USER=3

# =============================================================================
# DIRECTUS (Backend Database)
# =============================================================================

# Production Directus URL
DIRECTUS_URL=https://directus-production-xxxx.up.railway.app

# Admin token for Directus (generate via Directus admin panel)
DIRECTUS_ADMIN_TOKEN=your_directus_admin_token_here

# =============================================================================
# REDIS (Message Queue & Pub/Sub)
# =============================================================================

# Production Redis URL (from Railway, Upstash, or other provider)
# Format: redis://[username]:[password]@[host]:[port]
REDIS_URL=redis://default:your_redis_password@your-redis-host.railway.app:24137

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# Primary LLM provider (Chutes)
CHUTES_API_KEY=your_chutes_api_key
CHUTES_BASE_URL=https://llm.chutes.ai/v1
CHUTES_MODEL=moonshotai/Kimi-K2.5-TEE

# Fallback LLM providers (optional)
# OPENROUTER_API_KEY=your_openrouter_key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# GITHUB APP CONFIGURATION
# =============================================================================

# GitHub App credentials
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your_private_key_here
-----END RSA PRIVATE KEY-----"

# Workflow configuration
GITHUB_WORKFLOW_FILE=agent-security-scan.yml
GITHUB_SCAN_ARTIFACT_NAME=Certified-Security-Scan-Report
GITHUB_SCAN_RESULT_FILE_NAME=scan-result.json

# Platform workflow repository (where the scan workflow runs)
GITHUB_PLATFORM_WORKFLOW_OWNER=agentdeploy-io
GITHUB_PLATFORM_WORKFLOW_REPO=agentdeploy-scan-runner
GITHUB_PLATFORM_WORKFLOW_REF=main

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================

# WebSocket token secret (generate: openssl rand -hex 32)
# MUST match the frontend's SCAN_WS_TOKEN_SECRET
SCAN_WS_TOKEN_SECRET=your_websocket_token_secret_here

# Scanner WebSocket URL (for frontend to connect to)
# This should be the public URL where the scanner service is hosted
SCANNER_WS_URL=wss://scanner-production.xxxx.railway.app

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Production frontend URL
FRONTEND_URL=https://agentdeploy.xyz

# Port (use 3001 for scanner service)
PORT=3001

# Log level (info, warn, error)
LOG_LEVEL=info

# Node environment
NODE_ENV=production

# =============================================================================
# SCAN WORKFLOW CONFIGURATION
# =============================================================================

# Workflow config sync mode: manual (recommended for production)
# In manual mode, secrets must be configured manually in the workflow repo
SCAN_WORKFLOW_CONFIG_SYNC_MODE=manual

# =============================================================================
# MAINTENANCE CONFIGURATION
# =============================================================================

# Scan maintenance interval in seconds (default: 300 = 5 minutes)
SCAN_MAINTENANCE_INTERVAL_SECONDS=300

# =============================================================================
# STATE TTL CONFIGURATION
# =============================================================================

# How long to keep scan state in Redis (in seconds)
# Default: 3600 (1 hour) - should be longer than max scan duration
SCAN_STATE_TTL_SECONDS=3600